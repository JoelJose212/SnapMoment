# --- DATABASE ---
POSTGRES_USER=snapmoment
POSTGRES_PASSWORD=generate_a_strong_password_here
POSTGRES_DB=snapmoment
DATABASE_URL=postgresql+asyncpg://snapmoment:GENERATE_PASSWORD@postgres:5432/snapmoment

# --- REDIS ---
REDIS_URL=redis://redis:6379/0

# --- SECURITY ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=generate_a_secure_random_hex_key_for_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# --- ADMIN ---
ADMIN_EMAIL=admin@snapmoment.app
# Generate a hash for your password and put it here
ADMIN_PASSWORD_HASH=generate_bcrypt_hash_of_your_admin_password

# --- STORAGE (AWS S3) ---
USE_LOCAL_STORAGE=true
LOCAL_STORAGE_PATH=/app/uploads
LOCAL_STORAGE_BASE_URL=http://localhost:8000/uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=snapmoment-photos
AWS_REGION=ap-south-1

# --- MISC ---
DEV_MODE=true
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
